# ──────────────────────────────────────────────────────────────────────
# AI Control Plane Gateway – environment variable template
# Copy this file to `.env` and fill in the keys for providers you use.
#   cp .env.example .env
# Never commit `.env` (it's in .gitignore).
# ──────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_CONFIG=configs/config.yaml

# ── Provider API keys (set only the ones you need) ──────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
COHERE_API_KEY=
AI21_API_KEY=
HF_API_KEY=
REPLICATE_API_TOKEN=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Ollama is local and needs no key; leave unset.
