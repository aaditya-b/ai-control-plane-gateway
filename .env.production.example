# ──────────────────────────────────────────────────────────────────────────────
# AI Control Plane Gateway — Production Environment Variables
#
# SETUP:
#   cp .env.production.example .env.production
#   # Fill in every value marked REQUIRED
#   # Never commit .env.production to git — it contains secrets
# ──────────────────────────────────────────────────────────────────────────────

# ── Authentication Mode ────────────────────────────────────────────────────────
# "api_key"  — static Bearer tokens only (default, no Azure setup needed)
# "entra_id" — Microsoft Entra ID JWTs only (set ENTRA_* vars below)
# "any"      — accept either (best for gradual migration)
GATEWAY_AUTH_MODE=api_key

# ── Gateway API Keys — used when GATEWAY_AUTH_MODE is "api_key" or "any" ───────
# Clients send: Authorization: Bearer <key>
# Generate with: openssl rand -hex 32
GATEWAY_API_KEY_1=your-secret-gateway-api-key-1
GATEWAY_API_KEY_2=your-secret-gateway-api-key-2

# ── Microsoft Entra ID — used when GATEWAY_AUTH_MODE is "entra_id" or "any" ────
# Find these in Azure Portal → Entra ID → App registrations → your app → Overview
# ENTRA_TENANT_ID  : "Directory (tenant) ID"
# ENTRA_CLIENT_ID  : "Application (client) ID"
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_CLIENT_ID=your-client-id-here

# ── Docker Image (set by CI/CD, override manually if needed) ──────────────────
DOCKER_IMAGE=ai-control-plane-gateway
IMAGE_TAG=latest

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Only populate the providers you want to use. Unused providers are skipped.

# OpenAI (REQUIRED — primary provider)
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# Mistral AI
MISTRAL_API_KEY=...

# Groq (fast open-source inference)
GROQ_API_KEY=gsk_...

# Together AI
TOGETHER_API_KEY=...

# DeepSeek
DEEPSEEK_API_KEY=...

# xAI (Grok)
XAI_API_KEY=xai-...

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# Fireworks AI
FIREWORKS_API_KEY=fw-...

# Cohere
COHERE_API_KEY=...

# AI21 Labs
AI21_API_KEY=...

# HuggingFace
HF_API_KEY=hf_...

# Replicate
REPLICATE_API_TOKEN=r8_...

# ── Monitoring & Alerting ─────────────────────────────────────────────────────

# Grafana admin password (REQUIRED)
GRAFANA_ADMIN_PASSWORD=change-me-use-a-strong-password

# Slack / Discord / PagerDuty webhook URL for alerts (optional)
# Slack:      https://hooks.slack.com/services/T.../B.../...
# Teams:      https://your-org.webhook.office.com/webhookb2/...
# PagerDuty:  https://events.pagerduty.com/v2/enqueue  (also set PAGERDUTY_ROUTING_KEY)
# Generic:    any URL accepting POST JSON
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# PagerDuty only — 32-char integration key from your PagerDuty service
PAGERDUTY_ROUTING_KEY=

# ── Server & Deployment ───────────────────────────────────────────────────────

# Your public domain name (REQUIRED)
DOMAIN=api.yourdomain.com

# SSL certificate email (used by Let's Encrypt — REQUIRED for SSL)
CERTBOT_EMAIL=you@yourdomain.com

# Number of uvicorn workers (default: 4 — set to 2x vCPU count)
# GATEWAY_WORKERS=4
